{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project XC curated functional record",
  "type": "object",
  "required": [
    "slug",
    "canonical_name",
    "aliases",
    "summary",
    "family",
    "rung",
    "kind",
    "ingredients",
    "libxc",
    "references",
    "curation_status"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "canonical_name": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "family": {
      "type": "string"
    },
    "rung": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "exchange",
        "correlation",
        "exchange-correlation",
        "kinetic"
      ]
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "libxc": {
      "type": "object"
    },
    "parameters": {
      "type": "object"
    },
    "references": {
      "type": "array"
    },
    "program_aliases": {
      "type": "array"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "curation_status": {
      "type": "string"
    }
  }
}
